{
  "compilerOptions": {
    "target": "esnext",
    "module": "commonjs",
    "lib": ["ES2022"],
    "moduleResolution": "node",
    "types": ["node", "mocha"],
    "esModuleInterop": true,
    "strict": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "declaration": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "baseUrl": ".",
    "paths": {
      "@antelopejs/interface-redis-scheduler": ["src/index.ts"]
    }
  },
  "include": ["src"]
}
